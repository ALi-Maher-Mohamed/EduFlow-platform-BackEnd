                  "    pm.environment.set(\"COURSE_ID\", response.data._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Complete React Guide", "type": "text" },
                { "key": "description", "value": "Learn React from scratch with hooks, routing, and state management", "type": "text" },
                { "key": "category", "value": "web-development", "type": "text" },
                { "key": "thumbnail", "type": "file", "src": [], "disabled": true }
              ]
            },
            "url": {
              "raw": "{{URL}}/api/courses",
              "host": ["{{URL}}"],
              "path": ["api", "courses"]
            }
          }
        },
