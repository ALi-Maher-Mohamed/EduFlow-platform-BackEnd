    {
      "name": "Courses",
      "item": [
        {
          "name": "Get All Courses",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{URL}}/api/courses?page=1&limit=10&sort=newest",
              "host": ["{{URL}}"],
              "path": ["api", "courses"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "sort", "value": "newest", "description": "newest | popular | rating" },
                { "key": "search", "value": "react", "disabled": true },
                { "key": "category", "value": "web-development", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Single Course",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{URL}}/api/courses/{{COURSE_ID}}",
              "host": ["{{URL}}"],
              "path": ["api", "courses", "{{COURSE_ID}}"]
            }
          }
        },
        {
          "name": "Create Course (Form Data)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
